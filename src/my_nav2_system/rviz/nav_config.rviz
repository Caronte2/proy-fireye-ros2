Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/Map
      Enabled: true
      Name: Map
      Topic: /map
      Durability Policy: Transient Local
    - Class: rviz_default_plugins/LaserScan
      Enabled: true
      Name: LaserScan
      Topic: /scan
      Size (Pixels): 3
    - Class: rviz_default_plugins/PoseArray
      Enabled: true
      Name: Particulas_AMCL
      Topic: /particlecloud
  Global Options:
    Fixed Frame: map
